# Anthropic API key (falls back to backend/.env if not set here)
ANTHROPIC_API_KEY=

# X (Twitter) API v2 — get from developer.x.com
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Bluesky — generate app password at bsky.app/settings/app-passwords
BLUESKY_HANDLE=endlessrumination.bsky.social
BLUESKY_APP_PASSWORD=

# App links (update once live on stores)
APP_STORE_URL=
PLAY_STORE_URL=
WEBSITE_URL=https://github.com/snowygonzales/EndlessRumination
